# ── Server identity ───────────────────────────────────────────────────────────
HOTEL_MCP_SERVER_NAME="hotel-mcp-server"
HOTEL_MCP_LOG_LEVEL="INFO"       # DEBUG | INFO | WARNING | ERROR
HOTEL_MCP_ENV="development"       # development | staging | production

# ── PMS adapter ───────────────────────────────────────────────────────────────
# Adapter to load: "opera" | "cloudbeds" | "mews" | "mock"
PMS_ADAPTER="mock"
PMS_BASE_URL="https://pms.yourdomain.com/api/v1"
PMS_API_KEY=""                    # injected from secret manager in production
PMS_PROPERTY_ID=""
PMS_TIMEOUT_SECONDS="10"
PMS_RATE_LIMIT_RPS="5"           # requests per second

# ── CRM adapter ───────────────────────────────────────────────────────────────
# Adapter to load: "salesforce" | "hubspot" | "apaleo" | "mock"
CRM_ADAPTER="mock"
CRM_BASE_URL="https://api.salesforce.com"
CRM_API_KEY=""
CRM_INSTANCE_URL=""               # Salesforce-specific
CRM_TIMEOUT_SECONDS="10"
CRM_RATE_LIMIT_RPS="3"

# ── Authentication & authorisation ────────────────────────────────────────────
# MCP caller tokens — comma-separated. Replace with OAuth / OIDC in production.
MCP_ALLOWED_TOKENS=""
MCP_REQUIRE_AUTH="false"          # set true in production

# ── Audit log ─────────────────────────────────────────────────────────────────
AUDIT_LOG_FILE="./audit.jsonl"    # rotate with logrotate or ship to SIEM
AUDIT_INCLUDE_RESPONSE_HASH="true"

# ── Privacy / data residency (GDPR) ───────────────────────────────────────────
DATA_RESIDENCY_REGION="eu-west"
PII_FIELDS_MASK_IN_LOGS="email,phone,passport_number,credit_card"
